# Convex
NEXT_PUBLIC_CONVEX_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk Routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Resend — Email notifications (optional — emails disabled if not set)
# For Convex: npx convex env set RESEND_API_KEY <your-key>
RESEND_API_KEY=
# Optional: Verified sender address (defaults to onboarding@resend.dev for development)
# For Convex: npx convex env set RESEND_FROM_EMAIL "RedBox <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=
